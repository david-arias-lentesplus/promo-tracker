{
  "version": 2,
  "builds": [
    {
      "src": "api/login.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/users.json"
        ]
      }
    },
    {
      "src": "api/raw_data.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/url_sku_images.csv",
          "data/sku_use_data.csv"
        ]
      }
    },
    {
      "src": "api/stats.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/url_sku_images.csv",
          "data/sku_use_data.csv"
        ]
      }
    },
    {
      "src": "api/hs_info.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/url_sku_images.csv",
          "data/sku_use_data.csv"
        ]
      }
    },
    {
      "src": "api/campaigns.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/url_sku_images.csv",
          "data/sku_use_data.csv"
        ]
      }
    },
    {
      "src": "api/users.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/users.json"
        ]
      }
    },
    {
      "src": "api/me.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/users.json"
        ]
      }
    },
    {
      "src": "api/notifications.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/url_sku_images.csv",
          "data/sku_use_data.csv"
        ]
      }
    },
    {
      "src": "api/analytics.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/url_sku_images.csv",
          "data/sku_use_data.csv"
        ]
      }
    },
    {
      "src": "api/scraper.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/scraper_stats.json"
        ]
      }
    },
    {
      "src": "api/scraper_stats.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py",
          "data/scraper_stats.json"
        ]
      }
    },
    {
      "src": "api/promo.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py"
        ]
      }
    },
    {
      "src": "api/mcp_debug.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/_*.py"
        ]
      }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.py"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|ico|woff|woff2|ttf|map))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Authorization, Content-Type"
        }
      ]
    }
  ],
  "build": {
    "env": {
      "ELECTRON_SKIP_BINARY_DOWNLOAD": "1",
      "ELECTRON_BUILDER_BINARIES_SKIP_DOWNLOAD": "1"
    }
  }
}