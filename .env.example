# ─────────────────────────────────────────────────────────────────
# E-Commerce Promo Tracker & Analytics — Variables de Entorno
# Copiar este archivo como .env para desarrollo local.
# En producción, configurar estas variables en Vercel Dashboard.
# ⚠️  NUNCA commitear el archivo .env real al repositorio.
# ─────────────────────────────────────────────────────────────────

# JWT — Clave secreta para firmar tokens (mín. 32 caracteres aleatorios)
JWT_SECRET=cambia-esto-por-una-clave-muy-segura-y-larga

# Credenciales del administrador del dashboard
ADMIN_USER=admin
# SHA-256 de la contraseña. Generar con: python3 -c "import hashlib; print(hashlib.sha256('tu-pass'.encode()).hexdigest())"
ADMIN_PASSWORD_HASH=

# URL base del e-commerce a auditar (sin slash final)
ECOMMERCE_URL=https://tu-tienda.com

# Entorno (development | production)
NODE_ENV=development
