# ─────────────────────────────────────────────────────────────────
# E-Commerce Promo Tracker & Analytics — Variables de Entorno
# Copiar este archivo como .env para desarrollo local.
# En producción, configurar estas variables en Vercel Dashboard.
# ⚠️  NUNCA commitear el archivo .env real al repositorio.
# ─────────────────────────────────────────────────────────────────

# JWT — Clave secreta para firmar tokens (mín. 32 caracteres aleatorios)
JWT_SECRET=479bbc4055bd3f4f609627e67ea5a4e65f7e109e37978c843d888880552871e9

# Credenciales del administrador del dashboard
ADMIN_USER=admin
# SHA-256 de la contraseña. Generar con:
# python3 -c "import hashlib; print(hashlib.sha256('tu-pass'.encode()).hexdigest())"
ADMIN_PASSWORD_HASH=

# URL base del e-commerce a auditar (sin slash final)
ECOMMERCE_URL=https://www.lentesplus.com

# ─── DWH / Metabase MCP ──────────────────────────────────────────
# URL base del servidor MCP de Metabase (sin api_key)
METABASE_MCP_URL=https://mcp.livocompany.com/metabase/mcp
# API Key de Metabase MCP
METABASE_MCP_KEY=af7bd32eba834141058b8b453f07db8437dbd140bac1c92499e445e63912776b

# ─── AI / Anthropic ──────────────────────────────────────────────
# API Key de Anthropic para análisis AI en Promo Performance
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Entorno (development | production)
NODE_ENV=development
