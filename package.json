{
  "name": "promo-tracker-dashboard",
  "version": "1.0.0",
  "description": "E-Commerce Promo Tracker & Analytics — Internal Dashboard",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "app": "electron .",
    "app:dev": "NODE_ENV=development electron .",
    "app:build": "node electron/build-prep.cjs && electron-builder --dir --mac"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.lentesplus.promos-ss",
    "productName": "Promos SS",
    "copyright": "Copyright © 2026 lentesplus.com",
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/project-root.txt",
        "to": "project-root.txt"
      }
    ],
    "directories": {
      "output": "dist-electron"
    }
  }
}
